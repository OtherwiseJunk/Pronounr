{
  "name": "pronounr",
  "version": "0.1.0",
  "description": "Context-aware third-person pronoun replacement for English text. Swap one person's pronouns to any supported set (incl. neopronouns), with POS-based disambiguation of syncretic forms.",
  "keywords": [
    "pronouns",
    "neopronouns",
    "gender",
    "nlp",
    "text-replacement"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OtherwiseJunk/Pronounr.git"
  },
  "homepage": "https://github.com/OtherwiseJunk/Pronounr#readme",
  "bugs": {
    "url": "https://github.com/OtherwiseJunk/Pronounr/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "compromise": "^14.14.4"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
